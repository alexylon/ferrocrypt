// Ferrocrypt Slint GUI — Dark Security Theme

global Theme {
    // Backgrounds
    out property <color> bg: #0a0f1a;
    out property <color> surface: #111827;
    out property <color> surface-hover: #1c2536;
    out property <color> input-bg: #0f172a;

    // Borders
    out property <color> border: #1e293b;
    out property <color> border-hover: #334155;
    out property <color> border-focus: #06b6d4;

    // Disabled
    out property <color> input-bg-disabled: #0b0f1c;

    // Text
    out property <color> text: #e2e8f0;
    out property <color> text-secondary: #94a3b8;
    out property <color> text-dim: #64748b;
    out property <color> text-disabled: #475569;
    out property <color> text-off: #334155;

    // Accents
    out property <color> accent: #06b6d4;
    out property <color> accent-muted: #164e63;
    out property <color> accent-btn: #0e7490;
    out property <color> accent-btn-hover: #0891b2;

    // Status — muted to sit well on the dark navy background
    out property <color> success: #34d399;   // emerald-400, teal-tinted
    out property <color> error: #f87171;     // red-400, soft rose
    out property <color> warning: #d4a053;   // desaturated warm amber
}

// ---------------------------------------------------------------------------
// Reusable: small outline button
// ---------------------------------------------------------------------------
component SmallButton inherits Rectangle {
    in property <string> label;
    in property <bool> enabled: true;
    callback clicked();

    height: 34px;
    border-radius: 6px;
    background: !root.enabled ? Theme.surface :
                ta.has-hover   ? Theme.surface-hover : Theme.surface;
    border-width: 1px;
    border-color: Theme.border;
    animate background { duration: 120ms; }

    ta := TouchArea {
        enabled: root.enabled;
        mouse-cursor: root.enabled ? pointer : default;
        clicked => { root.clicked(); }
    }

    Text {
        text: root.label;
        color: root.enabled ? Theme.text-secondary : Theme.text-disabled;
        font-size: 12px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

// ---------------------------------------------------------------------------
// Main application window
// ---------------------------------------------------------------------------
export component AppWindow inherits Window {
    title: "Ferrocrypt";
    background: Theme.bg;
    width: 400px;
    height: 550px;

    // ── State ───────────────────────────────────────────────────────────
    // Mode: 0=SE  1=SD  2=HE  3=HD  4=GK
    in-out property <int> mode: 0;
    in-out property <string> inpath;
    in-out property <string> inpath-display;
    in-out property <string> outpath;
    in-out property <string> outpath-display;
    in-out property <string> password;
    in-out property <string> password-repeated;
    in-out property <string> keypath;
    in-out property <string> keypath-display;
    in-out property <string> status-ok;
    in-out property <string> status-err;
    in-out property <bool> hide-password: true;
    in-out property <bool> is-working: false;
    in-out property <bool> combined-picker: false;
    in-out property <string> conflict-warning;

    // ── Derived ─────────────────────────────────────────────────────────
    property <bool> require-password:
        mode == 0 || mode == 1 || mode == 3 || mode == 4;
    property <bool> require-password-repeated:
        (mode == 0 || mode == 4) && hide-password;
    property <bool> require-key: mode == 2 || mode == 3;
    property <bool> password-match: password == password-repeated;
    property <bool> disable-start: is-working
        || (mode == 0 && (inpath == "" || password == ""
            || (require-password-repeated && !password-match)))
        || (mode == 1 && (inpath == "" || password == ""))
        || (mode == 2 && (inpath == "" || keypath == ""))
        || (mode == 3 && (inpath == "" || password == "" || keypath == ""))
        || (mode == 4 && (outpath == "" || password == ""
            || (require-password-repeated && !password-match)));
    property <bool> is-encrypt-mode: mode == 0 || mode == 2;
    property <bool> form-is-clean:
        mode == 0 && hide-password
        && inpath == "" && outpath == "" && password == ""
        && password-repeated == "" && keypath == ""
        && conflict-warning == "" && status-ok == "" && status-err == "";
    property <string> button-text:
        mode == 0 || mode == 2 ? "Encrypt" :
        mode == 1 || mode == 3 ? "Decrypt" : "Generate Key Pair";

    // ── Callbacks ───────────────────────────────────────────────────────
    callback mode-changed();
    callback select-input-file();
    callback select-input-folder();
    callback select-key-file();
    callback select-output-dir();
    callback select-output-file();
    callback start-operation();
    callback clear-form();

    // ── Accent stripe ───────────────────────────────────────────────────
    Rectangle {
        y: 0;
        width: 100%;
        height: 2px;
        background: @linear-gradient(90deg, #0a0f1a, #06b6d4 50%, #0a0f1a);
    }

    // ── Main layout ─────────────────────────────────────────────────────
    VerticalLayout {
        padding-left: 22px;
        padding-right: 22px;
        padding-top: 28px;
        padding-bottom: 14px;
        spacing: 0px;

        // ── Top section: packs tightly at the top ──
        VerticalLayout {
            spacing: 0px;
            alignment: start;

        // ═══════════ HEADER ═══════════
        Text {
            text: "FERROCRYPT";
            color: Theme.text;
            font-size: 20px;
            font-weight: 700;
            horizontal-alignment: center;
        }
        Rectangle { height: 4px; }
        Text {
            text: "Secure File Encryption";
            color: Theme.text-dim;
            font-size: 12px;
            horizontal-alignment: center;
        }

        Rectangle { height: 22px; }

        // ═══════════ MODE SELECTOR ═══════════
        Rectangle {
            height: 38px;
            border-radius: 6px;
            background: Theme.input-bg;
            border-width: 1px;
            border-color: Theme.border;

            HorizontalLayout {
                padding: 3px;
                spacing: 2px;

                // ── Symmetric ──
                Rectangle {
                    horizontal-stretch: 1;
                    border-radius: 5px;
                    background: (mode == 0 || mode == 1) ? Theme.accent-muted :
                                (sym-ta.has-hover && sym-ta.enabled) ? Theme.surface-hover
                                : transparent;
                    animate background { duration: 150ms; }

                    sym-ta := TouchArea {
                        enabled: mode != 3 && !is-working;
                        mouse-cursor: self.enabled ? pointer : default;
                        clicked => { root.mode = 0; root.mode-changed(); }
                    }
                    Text {
                        text: "Symmetric";
                        color: (mode == 0 || mode == 1) ? Theme.text :
                               !sym-ta.enabled ? Theme.text-off : Theme.text-secondary;
                        font-size: 12.5px;
                        font-weight: (mode == 0 || mode == 1) ? 600 : 400;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Rectangle { width: 1px; background: Theme.border; }

                // ── Hybrid ──
                Rectangle {
                    horizontal-stretch: 1;
                    border-radius: 5px;
                    background: (mode == 2 || mode == 3) ? Theme.accent-muted :
                                (hyb-ta.has-hover && hyb-ta.enabled) ? Theme.surface-hover
                                : transparent;
                    animate background { duration: 150ms; }

                    hyb-ta := TouchArea {
                        enabled: mode != 1 && !is-working;
                        mouse-cursor: self.enabled ? pointer : default;
                        clicked => { root.mode = 2; root.mode-changed(); }
                    }
                    Text {
                        text: "Hybrid";
                        color: (mode == 2 || mode == 3) ? Theme.text :
                               !hyb-ta.enabled ? Theme.text-off : Theme.text-secondary;
                        font-size: 12.5px;
                        font-weight: (mode == 2 || mode == 3) ? 600 : 400;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Rectangle { width: 1px; background: Theme.border; }

                // ── Key Gen ──
                Rectangle {
                    horizontal-stretch: 1;
                    border-radius: 5px;
                    background: mode == 4 ? Theme.accent-muted :
                                (kg-ta.has-hover && kg-ta.enabled) ? Theme.surface-hover
                                : transparent;
                    animate background { duration: 150ms; }

                    kg-ta := TouchArea {
                        enabled: mode != 1 && mode != 3
                                 && (mode == 4 || inpath == "")
                                 && !is-working;
                        mouse-cursor: self.enabled ? pointer : default;
                        clicked => { root.mode = 4; root.mode-changed(); }
                    }
                    Text {
                        text: "Key Gen";
                        color: mode == 4 ? Theme.text :
                               !kg-ta.enabled ? Theme.text-off : Theme.text-secondary;
                        font-size: 12.5px;
                        font-weight: mode == 4 ? 600 : 400;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        Rectangle { height: 6px; }
        Text {
            text: mode == 0 || mode == 1 ? "Password-based encryption" :
                  mode == 2 || mode == 3 ? "Public/private key encryption" :
                  "Generate RSA-4096 key pair";
            color: Theme.text-dim;
            font-size: 11.5px;
            horizontal-alignment: center;
            animate color { duration: 150ms; }
        }

        // ═══════════ INPUT FILE / FOLDER (hidden in Key Gen) ═══════════
        if mode != 4 : VerticalLayout {
            spacing: 0px;
            Rectangle { height: 22px; }

            Text {
                text: "Input file or folder";
                color: Theme.text-secondary;
                font-size: 12px;
            }
            Rectangle { height: 5px; }

            HorizontalLayout {
                spacing: 6px;

                Rectangle {
                    horizontal-stretch: 1;
                    height: 34px;
                    border-radius: 6px;
                    background: is-working ? Theme.input-bg-disabled : Theme.input-bg;
                    border-width: 1px;
                    border-color: !is-working && inpath-ta.has-hover
                                  ? Theme.border-hover : Theme.border;
                    clip: true;
                    animate background { duration: 150ms; }
                    animate border-color { duration: 150ms; }

                    inpath-ta := TouchArea {
                        enabled: !is-working;
                        mouse-cursor: self.enabled ? pointer : default;
                        clicked => { root.select-input-file(); }
                    }

                    Text {
                        x: 10px;
                        width: parent.width - 20px;
                        vertical-alignment: center;
                        text: inpath != "" ? inpath-display : "No file selected";
                        color: inpath != "" ? Theme.text : Theme.text-disabled;
                        font-size: 12.5px;
                        overflow: elide;
                    }
                }

                if combined-picker : SmallButton {
                    width: 56px;
                    label: "Select";
                    enabled: !is-working;
                    clicked => { root.select-input-file(); }
                }
                if !combined-picker : SmallButton {
                    width: 42px;
                    label: "File";
                    enabled: !is-working;
                    clicked => { root.select-input-file(); }
                }
                if !combined-picker : SmallButton {
                    width: 52px;
                    label: "Folder";
                    enabled: !is-working;
                    clicked => { root.select-input-folder(); }
                }
            }
        }

        // ═══════════ PASSWORD (SE, SD, HD, GK) ═══════════
        if require-password : VerticalLayout {
            spacing: 0px;
            Rectangle { height: 24px; }

            Text {
                text: "Password";
                color: Theme.text-secondary;
                font-size: 12px;
            }
            Rectangle { height: 5px; }

            Rectangle {
                height: 34px;
                border-radius: 6px;
                background: is-working ? Theme.input-bg-disabled : Theme.input-bg;
                border-width: 1px;
                border-color: pwd-ti.has-focus ? Theme.border-focus :
                              pwd-hover.has-hover && !is-working
                              ? Theme.border-hover : Theme.border;
                animate background { duration: 150ms; }
                animate border-color { duration: 150ms; }

                pwd-hover := TouchArea {
                    enabled: !is-working;
                    mouse-cursor: text;
                    clicked => { pwd-ti.focus(); }
                }

                pwd-ti := TextInput {
                    x: 10px;
                    width: parent.width - 40px;
                    y: (parent.height - self.preferred-height) / 2;
                    color: Theme.text;
                    font-size: 13px;
                    input-type: hide-password ? InputType.password : InputType.text;
                    text <=> root.password;
                    single-line: true;
                    enabled: !is-working;
                    accepted => {
                        if (!root.disable-start) { root.start-operation(); }
                    }
                }

                if password == "" && !pwd-ti.has-focus : Text {
                    x: 10px;
                    y: (parent.height - self.preferred-height) / 2;
                    text: "Enter password\u{2026}";
                    color: Theme.text-disabled;
                    font-size: 13px;
                }

                // Eye icon (toggle password visibility)
                Rectangle {
                    x: parent.width - 32px;
                    y: (parent.height - 14px) / 2;
                    width: 22px;
                    height: 14px;

                    // Eye outline (oval)
                    Rectangle {
                        width: 18px;
                        height: 10px;
                        x: 2px;
                        y: 2px;
                        border-radius: 5px;
                        border-width: 1.5px;
                        border-color: Theme.text-dim;
                        background: transparent;

                        // Pupil
                        Rectangle {
                            width: 5px;
                            height: 5px;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            border-radius: 2.5px;
                            background: Theme.text-dim;
                        }
                    }

                    // Strike-through (when password is visible)
                    if (!root.hide-password) : Rectangle {
                        width: 22px;
                        height: 1.5px;
                        y: (parent.height - self.height) / 2;
                        background: Theme.text-dim;
                    }
                }

                // Clickable area for the eye
                TouchArea {
                    x: parent.width - 38px;
                    width: 38px;
                    height: parent.height;
                    mouse-cursor: pointer;
                    clicked => { root.hide-password = !root.hide-password; }
                }
            }
        }

        // ═══════════ CONFIRM PASSWORD (SE, GK — only when pwd hidden) ═══════════
        if require-password-repeated : VerticalLayout {
            spacing: 0px;
            Rectangle { height: 18px; }

            Text {
                text: "Confirm Password";
                color: Theme.text-secondary;
                font-size: 12px;
            }
            Rectangle { height: 5px; }

            Rectangle {
                property <bool> field-enabled: !is-working && password != "";
                height: 34px;
                border-radius: 6px;
                background: !field-enabled ? Theme.input-bg-disabled : Theme.input-bg;
                border-width: 1px;
                border-color: rpwd-ti.has-focus ? Theme.border-focus :
                              rpwd-hover.has-hover && field-enabled
                              ? Theme.border-hover : Theme.border;
                animate background { duration: 150ms; }
                animate border-color { duration: 150ms; }

                rpwd-hover := TouchArea {
                    enabled: parent.field-enabled;
                    mouse-cursor: self.enabled ? text : default;
                    clicked => { rpwd-ti.focus(); }
                }

                rpwd-ti := TextInput {
                    x: 10px;
                    width: parent.width - 36px;
                    y: (parent.height - self.preferred-height) / 2;
                    color: Theme.text;
                    font-size: 13px;
                    input-type: InputType.password;
                    text <=> root.password-repeated;
                    single-line: true;
                    enabled: parent.field-enabled;
                    accepted => {
                        if (!root.disable-start) { root.start-operation(); }
                    }
                }

                if password-repeated == "" && !rpwd-ti.has-focus : Text {
                    x: 10px;
                    y: (parent.height - self.preferred-height) / 2;
                    text: "Repeat password\u{2026}";
                    color: Theme.text-disabled;
                    font-size: 13px;
                }

                // Match dot (inside field, right edge)
                if password-repeated != "" : Rectangle {
                    x: parent.width - 22px;
                    y: (parent.height - 10px) / 2;
                    width: 10px;
                    height: 10px;
                    border-radius: 5px;
                    background: password-match ? Theme.success : Theme.error;
                    animate background { duration: 200ms; }
                }
            }
        }

        // ═══════════ RSA KEY (HE, HD) ═══════════
        if require-key : VerticalLayout {
            spacing: 0px;
            Rectangle { height: 24px; }

            Text {
                text: mode == 2 ? "Public Key (PEM)" : "Private Key (PEM)";
                color: Theme.text-secondary;
                font-size: 12px;
            }
            Rectangle { height: 5px; }

            HorizontalLayout {
                spacing: 6px;

                Rectangle {
                    horizontal-stretch: 1;
                    height: 34px;
                    border-radius: 6px;
                    background: is-working ? Theme.input-bg-disabled : Theme.input-bg;
                    border-width: 1px;
                    border-color: !is-working && key-ta.has-hover
                                  ? Theme.border-hover : Theme.border;
                    clip: true;
                    animate background { duration: 150ms; }
                    animate border-color { duration: 150ms; }

                    key-ta := TouchArea {
                        enabled: !is-working;
                        mouse-cursor: self.enabled ? pointer : default;
                        clicked => { root.select-key-file(); }
                    }

                    Text {
                        x: 10px;
                        width: parent.width - 20px;
                        vertical-alignment: center;
                        text: keypath != "" ? keypath-display :
                              (mode == 2 ? "Select public key\u{2026}" :
                               "Select private key\u{2026}");
                        color: keypath != "" ? Theme.text : Theme.text-disabled;
                        font-size: 12.5px;
                        overflow: elide;
                    }
                }

                SmallButton {
                    width: 56px;
                    label: "Select";
                    enabled: !is-working;
                    clicked => { root.select-key-file(); }
                }
            }
        }

        // ═══════════ OUTPUT (encrypt: file path, decrypt/keygen: directory) ═══════════
        VerticalLayout {
            spacing: 0px;
            Rectangle { height: 24px; }

            Text {
                text: is-encrypt-mode ? "Save encrypted file as" : "Output Directory";
                color: Theme.text-secondary;
                font-size: 12px;
            }
            Rectangle { height: 5px; }

            HorizontalLayout {
                spacing: 6px;

                Rectangle {
                    property <bool> field-enabled: !is-working && !(is-encrypt-mode && inpath == "");
                    horizontal-stretch: 1;
                    height: 34px;
                    border-radius: 6px;
                    background: !field-enabled ? Theme.input-bg-disabled : Theme.input-bg;
                    border-width: 1px;
                    border-color: field-enabled && out-ta.has-hover
                                  ? Theme.border-hover : Theme.border;
                    clip: true;
                    animate background { duration: 150ms; }
                    animate border-color { duration: 150ms; }

                    out-ta := TouchArea {
                        enabled: parent.field-enabled;
                        mouse-cursor: self.enabled ? pointer : default;
                        clicked => {
                            if (is-encrypt-mode) {
                                root.select-output-file();
                            } else {
                                root.select-output-dir();
                            }
                        }
                    }

                    Text {
                        x: 10px;
                        width: parent.width - 20px;
                        vertical-alignment: center;
                        text: outpath != "" ? outpath-display :
                              (is-encrypt-mode ? "No file selected" : "No directory selected");
                        color: outpath != "" ? Theme.text : Theme.text-disabled;
                        font-size: 12.5px;
                        overflow: elide;
                    }
                }

                SmallButton {
                    width: 64px;
                    label: "Change";
                    enabled: !is-working && !(is-encrypt-mode && inpath == "");
                    clicked => {
                        if (is-encrypt-mode) {
                            root.select-output-file();
                        } else {
                            root.select-output-dir();
                        }
                    }
                }
            }
        }

        } // end top section

        // ── Spacer: pushes bottom section to a fixed position ──
        Rectangle { vertical-stretch: 1; }

        // ── Bottom section: always at the same position ──

        // ═══════════ NOTIFICATION BAR ═══════════
        // Priority: error > warning > success/progress. Only one shown at a time.
        Rectangle {
            height: 30px;
            border-radius: 6px;
            background: status-err != "" ? #1c1012 :
                        conflict-warning != "" ? #1a1708 :
                        status-ok != "" ? #0a1a14 : transparent;
            border-width: (status-err != "" || conflict-warning != "" || status-ok != "") ? 1px : 0px;
            border-color: status-err != "" ? #3b1520 :
                          conflict-warning != "" ? #3b3015 :
                          status-ok != "" ? #153b2a : transparent;
            animate background { duration: 200ms; }
            animate border-color { duration: 200ms; }

            Text {
                x: 10px;
                width: parent.width - 20px;
                vertical-alignment: center;
                text: status-err != "" ? status-err :
                      conflict-warning != "" ? conflict-warning :
                      status-ok;
                color: status-err != "" ? Theme.error :
                       conflict-warning != "" ? Theme.warning :
                       Theme.success;
                font-size: 11.5px;
                overflow: elide;
            }
        }

        Rectangle { height: 12px; }

        // ═══════════ ACTION ROW ═══════════
        HorizontalLayout {
            spacing: 8px;

            Rectangle {
                width: 54px;
                height: 40px;
                border-radius: 6px;
                background: form-is-clean || is-working ? transparent :
                            reset-ta.has-hover ? Theme.surface-hover : transparent;
                border-width: form-is-clean || is-working ? 0px : 1px;
                border-color: Theme.border;
                animate background { duration: 120ms; }
                animate border-width { duration: 120ms; }

                reset-ta := TouchArea {
                    enabled: !form-is-clean && !is-working;
                    mouse-cursor: self.enabled ? pointer : default;
                    clicked => { root.clear-form(); }
                }

                Text {
                    text: "Reset";
                    color: form-is-clean || is-working ? Theme.text-off : Theme.text-dim;
                    font-size: 11.5px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            Rectangle {
                horizontal-stretch: 1;
                height: 40px;
                border-radius: 6px;
                background: disable-start ? Theme.surface :
                            start-ta.has-hover ? Theme.accent-btn-hover
                            : Theme.accent-btn;
                animate background { duration: 120ms; }

                start-ta := TouchArea {
                    enabled: !disable-start;
                    mouse-cursor: self.enabled ? pointer : default;
                    clicked => { root.start-operation(); }
                }

                Text {
                    text: button-text;
                    color: disable-start ? Theme.text-disabled : Theme.text;
                    font-size: 14px;
                    font-weight: 600;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        Rectangle { height: 10px; }

    }
}
