// Ferrocrypt Slint GUI — Dark Security Theme

global Theme {
    // Backgrounds
    out property <color> bg: #0a0f1a;
    out property <color> surface: #111827;
    out property <color> surface-hover: #1c2536;
    out property <color> input-bg: #0f172a;

    // Borders
    out property <color> border: #1e293b;
    out property <color> border-hover: #334155;
    out property <color> border-focus: #06b6d4;

    // Text
    out property <color> text: #e2e8f0;
    out property <color> text-secondary: #94a3b8;
    out property <color> text-dim: #64748b;
    out property <color> text-disabled: #475569;
    out property <color> text-off: #334155;

    // Accents
    out property <color> accent: #06b6d4;
    out property <color> accent-muted: #164e63;
    out property <color> accent-btn: #0e7490;
    out property <color> accent-btn-hover: #0891b2;

    // Status
    out property <color> success: #22c55e;
    out property <color> error: #ef4444;
}

// ---------------------------------------------------------------------------
// Reusable: small outline button
// ---------------------------------------------------------------------------
component SmallButton inherits Rectangle {
    in property <string> label;
    in property <bool> enabled: true;
    callback clicked();

    height: 34px;
    border-radius: 6px;
    background: !root.enabled ? Theme.surface :
                ta.has-hover   ? Theme.surface-hover : Theme.surface;
    border-width: 1px;
    border-color: Theme.border;
    animate background { duration: 120ms; }

    ta := TouchArea {
        enabled: root.enabled;
        mouse-cursor: root.enabled ? pointer : default;
        clicked => { root.clicked(); }
    }

    Text {
        text: root.label;
        color: root.enabled ? Theme.text-secondary : Theme.text-disabled;
        font-size: 12px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

// ---------------------------------------------------------------------------
// Main application window
// ---------------------------------------------------------------------------
export component AppWindow inherits Window {
    title: "Ferrocrypt";
    background: Theme.bg;
    preferred-width: 470px;
    preferred-height: 700px;
    min-width: 440px;
    min-height: 660px;

    // ── State ───────────────────────────────────────────────────────────
    // Mode: 0=SE  1=SD  2=HE  3=HD  4=GK
    in-out property <int> mode: 0;
    in-out property <string> inpath;
    in-out property <string> outpath;
    in-out property <string> password;
    in-out property <string> password-repeated;
    in-out property <string> keypath;
    in-out property <string> status-ok: "Ready";
    in-out property <string> status-err;
    in-out property <bool> hide-password: true;
    in-out property <bool> is-working: false;
    in-out property <bool> combined-picker: false;

    // ── Derived ─────────────────────────────────────────────────────────
    property <bool> require-password:
        mode == 0 || mode == 1 || mode == 3 || mode == 4;
    property <bool> require-password-repeated:
        (mode == 0 || mode == 4) && hide-password;
    property <bool> require-key: mode == 2 || mode == 3;
    property <bool> password-match: password == password-repeated;
    property <bool> disable-start: is-working
        || (mode == 0 && (inpath == "" || password == ""
            || (require-password-repeated && !password-match)))
        || (mode == 1 && (inpath == "" || password == ""))
        || (mode == 2 && (inpath == "" || keypath == ""))
        || (mode == 3 && (inpath == "" || password == "" || keypath == ""))
        || (mode == 4 && (outpath == "" || password == ""
            || (require-password-repeated && !password-match)));
    property <string> button-text:
        mode == 0 || mode == 2 ? "Encrypt" :
        mode == 1 || mode == 3 ? "Decrypt" : "Generate Key Pair";

    // ── Callbacks ───────────────────────────────────────────────────────
    callback select-input-file();
    callback select-input-folder();
    callback select-key-file();
    callback select-output-dir();
    callback start-operation();
    callback clear-form();

    // ── Accent stripe ───────────────────────────────────────────────────
    Rectangle {
        y: 0;
        width: 100%;
        height: 2px;
        background: @linear-gradient(90deg, #0a0f1a, #06b6d4 50%, #0a0f1a);
    }

    // ── Main layout ─────────────────────────────────────────────────────
    VerticalLayout {
        padding-left: 22px;
        padding-right: 22px;
        padding-top: 28px;
        padding-bottom: 14px;
        spacing: 0px;

        // ═══════════ HEADER ═══════════
        Text {
            text: "FERROCRYPT";
            color: Theme.text;
            font-size: 20px;
            font-weight: 700;
            horizontal-alignment: center;
        }
        Rectangle { height: 4px; }
        Text {
            text: "Secure File Encryption";
            color: Theme.text-dim;
            font-size: 12px;
            horizontal-alignment: center;
        }

        Rectangle { height: 18px; }
        Rectangle { height: 1px; background: Theme.border; }
        Rectangle { height: 16px; }

        // ═══════════ INPUT FILE / FOLDER ═══════════
        Text {
            text: mode == 4 ? " " : "Input file or folder";
            color: mode == 4 ? transparent : Theme.text-secondary;
            font-size: 12px;
        }
        Rectangle { height: 5px; }

        HorizontalLayout {
            spacing: 6px;

            // Path display
            Rectangle {
                horizontal-stretch: 1;
                height: 34px;
                border-radius: 6px;
                background: Theme.input-bg;
                border-width: 1px;
                border-color: Theme.border;
                clip: true;

                Text {
                    x: 10px;
                    width: parent.width - 20px;
                    vertical-alignment: center;
                    text: mode == 4 ? "" :
                          (inpath != "" ? inpath : "No file selected");
                    color: inpath != "" && mode != 4 ? Theme.text : Theme.text-disabled;
                    font-size: 12.5px;
                    overflow: elide;
                }
            }

            if combined-picker : SmallButton {
                width: 56px;
                label: "Select";
                enabled: mode != 4 && !is-working;
                clicked => { root.select-input-file(); }
            }
            if !combined-picker : SmallButton {
                width: 42px;
                label: "File";
                enabled: mode != 4 && !is-working;
                clicked => { root.select-input-file(); }
            }
            if !combined-picker : SmallButton {
                width: 52px;
                label: "Folder";
                enabled: mode != 4 && !is-working;
                clicked => { root.select-input-folder(); }
            }
            SmallButton {
                width: 46px;
                label: "Clear";
                enabled: !is-working;
                clicked => { root.clear-form(); }
            }
        }

        Rectangle { height: 16px; }

        // ═══════════ MODE SELECTOR ═══════════
        Rectangle {
            height: 38px;
            border-radius: 6px;
            background: Theme.input-bg;
            border-width: 1px;
            border-color: Theme.border;

            HorizontalLayout {
                padding: 3px;
                spacing: 2px;

                // ── Symmetric ──
                Rectangle {
                    horizontal-stretch: 1;
                    border-radius: 5px;
                    background: (mode == 0 || mode == 1) ? Theme.accent-muted :
                                (sym-ta.has-hover && sym-ta.enabled) ? Theme.surface-hover
                                : transparent;
                    animate background { duration: 150ms; }

                    sym-ta := TouchArea {
                        enabled: mode != 3 && !is-working;
                        mouse-cursor: self.enabled ? pointer : default;
                        clicked => { root.mode = 0; }
                    }
                    Text {
                        text: "Symmetric";
                        color: (mode == 0 || mode == 1) ? Theme.text :
                               !sym-ta.enabled ? Theme.text-off : Theme.text-secondary;
                        font-size: 12.5px;
                        font-weight: (mode == 0 || mode == 1) ? 600 : 400;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Rectangle { width: 1px; background: Theme.border; }

                // ── Hybrid ──
                Rectangle {
                    horizontal-stretch: 1;
                    border-radius: 5px;
                    background: (mode == 2 || mode == 3) ? Theme.accent-muted :
                                (hyb-ta.has-hover && hyb-ta.enabled) ? Theme.surface-hover
                                : transparent;
                    animate background { duration: 150ms; }

                    hyb-ta := TouchArea {
                        enabled: mode != 1 && !is-working;
                        mouse-cursor: self.enabled ? pointer : default;
                        clicked => { root.mode = 2; }
                    }
                    Text {
                        text: "Hybrid";
                        color: (mode == 2 || mode == 3) ? Theme.text :
                               !hyb-ta.enabled ? Theme.text-off : Theme.text-secondary;
                        font-size: 12.5px;
                        font-weight: (mode == 2 || mode == 3) ? 600 : 400;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Rectangle { width: 1px; background: Theme.border; }

                // ── Key Gen ──
                Rectangle {
                    horizontal-stretch: 1;
                    border-radius: 5px;
                    background: mode == 4 ? Theme.accent-muted :
                                (kg-ta.has-hover && kg-ta.enabled) ? Theme.surface-hover
                                : transparent;
                    animate background { duration: 150ms; }

                    kg-ta := TouchArea {
                        enabled: mode != 1 && mode != 3
                                 && (mode == 4 || inpath == "")
                                 && !is-working;
                        mouse-cursor: self.enabled ? pointer : default;
                        clicked => { root.mode = 4; }
                    }
                    Text {
                        text: "Key Gen";
                        color: mode == 4 ? Theme.text :
                               !kg-ta.enabled ? Theme.text-off : Theme.text-secondary;
                        font-size: 12.5px;
                        font-weight: mode == 4 ? 600 : 400;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        Rectangle { height: 18px; }

        // ═══════════ PASSWORD ═══════════
        Text {
            text: "Password";
            color: require-password ? Theme.text-secondary : Theme.text-disabled;
            font-size: 12px;
        }
        Rectangle { height: 5px; }

        HorizontalLayout {
            spacing: 6px;

            Rectangle {
                horizontal-stretch: 1;
                height: 34px;
                border-radius: 6px;
                background: Theme.input-bg;
                border-width: 1px;
                border-color: pwd-ti.has-focus && require-password
                              ? Theme.border-focus : Theme.border;
                animate border-color { duration: 150ms; }

                pwd-ti := TextInput {
                    x: 10px;
                    width: parent.width - 20px;
                    y: (parent.height - self.preferred-height) / 2;
                    color: require-password ? Theme.text : transparent;
                    font-size: 13px;
                    input-type: hide-password ? InputType.password : InputType.text;
                    text <=> root.password;
                    single-line: true;
                    enabled: require-password && !is-working;
                    accepted => {
                        if !root.disable-start { root.start-operation(); }
                    }
                }

                // placeholder
                if password == "" && !pwd-ti.has-focus && require-password : Text {
                    x: 10px;
                    y: (parent.height - self.preferred-height) / 2;
                    text: "Enter password\u{2026}";
                    color: Theme.text-disabled;
                    font-size: 13px;
                }
            }

            // visibility toggle — always reserve 48px to keep layout stable
            Rectangle {
                width: 48px;
                height: 34px;

                if require-password : SmallButton {
                    width: 100%;
                    height: 100%;
                    label: hide-password ? "Show" : "Hide";
                    enabled: !is-working;
                    clicked => { root.hide-password = !root.hide-password; }
                }
            }
        }

        Rectangle { height: 14px; }

        // ═══════════ CONFIRM PASSWORD ═══════════
        Text {
            text: "Confirm Password";
            color: require-password-repeated ? Theme.text-secondary : Theme.text-disabled;
            font-size: 12px;
        }
        Rectangle { height: 5px; }

        HorizontalLayout {
            spacing: 6px;

            Rectangle {
                horizontal-stretch: 1;
                height: 34px;
                border-radius: 6px;
                background: Theme.input-bg;
                border-width: 1px;
                border-color: rpwd-ti.has-focus && require-password-repeated
                              ? Theme.border-focus : Theme.border;
                animate border-color { duration: 150ms; }

                rpwd-ti := TextInput {
                    x: 10px;
                    width: parent.width - 20px;
                    y: (parent.height - self.preferred-height) / 2;
                    color: require-password-repeated ? Theme.text : transparent;
                    font-size: 13px;
                    input-type: InputType.password;
                    text <=> root.password-repeated;
                    single-line: true;
                    enabled: require-password-repeated && !is-working;
                    accepted => {
                        if !root.disable-start { root.start-operation(); }
                    }
                }

                if password-repeated == "" && !rpwd-ti.has-focus
                   && require-password-repeated : Text {
                    x: 10px;
                    y: (parent.height - self.preferred-height) / 2;
                    text: "Repeat password\u{2026}";
                    color: Theme.text-disabled;
                    font-size: 13px;
                }
            }

            // match indicator — always reserve 48px to match password row width
            Rectangle {
                width: 48px;
                height: 34px;

                if require-password-repeated && password-repeated != "" : Rectangle {
                    width: 10px;
                    height: 10px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    border-radius: 5px;
                    background: password-match ? Theme.success : Theme.error;
                    animate background { duration: 200ms; }
                }
            }
        }

        Rectangle { height: 18px; }

        // ═══════════ RSA KEY ═══════════
        Text {
            text: mode == 2 ? "Public Key (PEM)" :
                  mode == 3 ? "Private Key (PEM)" : "RSA Key (PEM)";
            color: require-key ? Theme.text-secondary : Theme.text-disabled;
            font-size: 12px;
        }
        Rectangle { height: 5px; }

        HorizontalLayout {
            spacing: 6px;

            Rectangle {
                horizontal-stretch: 1;
                height: 34px;
                border-radius: 6px;
                background: Theme.input-bg;
                border-width: 1px;
                border-color: Theme.border;
                clip: true;

                Text {
                    x: 10px;
                    width: parent.width - 20px;
                    vertical-alignment: center;
                    text: keypath != "" ? keypath :
                          (mode == 2 ? "Select public key\u{2026}" :
                           mode == 3 ? "Select private key\u{2026}" : "");
                    color: keypath != "" && require-key
                           ? Theme.text : Theme.text-disabled;
                    font-size: 12.5px;
                    overflow: elide;
                }
            }

            SmallButton {
                width: 56px;
                label: "Select";
                enabled: require-key && !is-working;
                clicked => { root.select-key-file(); }
            }
        }

        Rectangle { height: 18px; }

        // ═══════════ OUTPUT DIRECTORY ═══════════
        Text {
            text: "Output Directory";
            color: Theme.text-secondary;
            font-size: 12px;
        }
        Rectangle { height: 5px; }

        HorizontalLayout {
            spacing: 6px;

            Rectangle {
                horizontal-stretch: 1;
                height: 34px;
                border-radius: 6px;
                background: Theme.input-bg;
                border-width: 1px;
                border-color: Theme.border;
                clip: true;

                Text {
                    x: 10px;
                    width: parent.width - 20px;
                    vertical-alignment: center;
                    text: outpath != "" ? outpath : "No directory selected";
                    color: outpath != "" ? Theme.text : Theme.text-disabled;
                    font-size: 12.5px;
                    overflow: elide;
                }
            }

            SmallButton {
                width: 56px;
                label: "Select";
                enabled: !is-working;
                clicked => { root.select-output-dir(); }
            }
        }

        Rectangle { height: 18px; }
        Rectangle { height: 1px; background: Theme.border; }
        Rectangle { height: 16px; }

        // ═══════════ ACTION ROW ═══════════
        HorizontalLayout {
            spacing: 8px;

            // Start / action button
            Rectangle {
                horizontal-stretch: 1;
                height: 40px;
                border-radius: 6px;
                background: disable-start ? Theme.surface :
                            start-ta.has-hover ? Theme.accent-btn-hover
                            : Theme.accent-btn;
                animate background { duration: 120ms; }

                start-ta := TouchArea {
                    enabled: !disable-start;
                    mouse-cursor: self.enabled ? pointer : default;
                    clicked => { root.start-operation(); }
                }

                Text {
                    text: button-text;
                    color: disable-start ? Theme.text-disabled : Theme.text;
                    font-size: 14px;
                    font-weight: 600;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        Rectangle { height: 12px; }

        // ═══════════ STATUS ═══════════
        if status-ok != "" : Text {
            text: status-ok;
            color: Theme.success;
            font-size: 12px;
            wrap: word-wrap;
        }
        if status-err != "" : Text {
            text: status-err;
            color: Theme.error;
            font-size: 12px;
            wrap: word-wrap;
        }

        // absorb remaining vertical space
        Rectangle { vertical-stretch: 1; }
    }
}
