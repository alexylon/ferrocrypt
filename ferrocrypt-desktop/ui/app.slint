// FerroCrypt Slint GUI — Dark Security Theme

global Theme {
    // Backgrounds
    out property <color> bg: #0a0f1a;
    out property <color> surface: #111827;
    out property <color> surface-hover: #1c2536;
    out property <color> input-bg: #0f172a;

    // Borders
    out property <color> border: #1e293b;
    out property <color> border-hover: #334155;
    out property <color> border-focus: #06b6d4;

    // Disabled
    out property <color> input-bg-disabled: #0b0f1c;

    // Text
    out property <color> text: #e2e8f0;
    out property <color> text-secondary: #94a3b8;
    out property <color> text-dim: #64748b;
    out property <color> text-disabled: #475569;
    out property <color> text-off: #334155;

    // Accents
    out property <color> accent: #06b6d4;
    out property <color> accent-muted: #164e63;
    out property <color> accent-btn: #0e7490;
    out property <color> accent-btn-hover: #0891b2;

    // Status — muted to sit well on the dark navy background
    out property <color> success: #34d399;   // emerald-400, teal-tinted
    out property <color> error: #f87171;     // red-400, soft rose
    out property <color> warning: #d4a053;   // desaturated warm amber

    // Layout
    out property <length> field-height: 34px;
    out property <length> field-radius: 6px;
    out property <length> field-gap: 18px;
    out property <length> label-gap: 5px;
    out property <length> label-size: 12px;
    out property <length> field-text-size: 12.5px;
    out property <length> input-text-size: 13px;
    out property <length> field-pad: 10px;
    out property <length> btn-width: 56px;
    out property <length> row-spacing: 6px;
}

// ---------------------------------------------------------------------------
// Reusable: small outline button
// ---------------------------------------------------------------------------
component SmallButton inherits Rectangle {
    in property <string> label;
    in property <bool> enabled: true;
    callback clicked();

    height: Theme.field-height;
    border-radius: Theme.field-radius;
    background: !root.enabled ? Theme.surface :
                ta.has-hover   ? Theme.surface-hover : Theme.surface;
    border-width: 1px;
    border-color: Theme.border;
    animate background { duration: 120ms; }

    ta := TouchArea {
        enabled: root.enabled;
        mouse-cursor: root.enabled ? pointer : default;
        clicked => { root.clicked(); }
    }

    Text {
        text: root.label;
        color: root.enabled ? Theme.text-secondary : Theme.text-disabled;
        font-size: Theme.label-size;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

// ---------------------------------------------------------------------------
// Main application window
// ---------------------------------------------------------------------------
export component AppWindow inherits Window {
    title: "FerroCrypt";
    background: Theme.bg;
    width: 450px;
    height: 700px;

    // ── State ───────────────────────────────────────────────────────────
    // Mode: 0=SE  1=SD  2=HE  3=HD  4=GK
    in-out property <int> mode: 0;
    in-out property <string> inpath;
    in-out property <string> inpath-display;
    in-out property <string> outpath;
    in-out property <string> outpath-display;
    in-out property <string> password;
    in-out property <string> password-repeated;
    in-out property <string> keypath;
    in-out property <string> keypath-display;
    in-out property <string> keygen-outdir;
    in-out property <string> keygen-outdir-display;
    in-out property <string> status-ok;
    in-out property <string> status-err;
    in-out property <bool> hide-password: true;
    in-out property <bool> is-working: false;
    in-out property <bool> combined-picker: false;
    in-out property <string> conflict-warning;
    in-out property <int> password-strength: 0;

    // ── Derived ─────────────────────────────────────────────────────────
    property <bool> require-password: mode != 2;
    property <bool> require-password-repeated:
        (mode == 0 || mode == 4) && hide-password;
    property <bool> require-key: mode == 2 || mode == 3;
    property <bool> password-match: password == password-repeated;
    property <bool> disable-start: is-working
        || (mode == 0 && (inpath == "" || password == ""
            || (require-password-repeated && !password-match)))
        || (mode == 1 && (inpath == "" || password == ""))
        || (mode == 2 && (inpath == "" || keypath == ""))
        || (mode == 3 && (inpath == "" || password == "" || keypath == ""))
        || (mode == 4 && (keygen-outdir == "" || password == ""
            || (require-password-repeated && !password-match)));
    property <bool> is-encrypt-mode: mode == 0 || mode == 2 || mode == 4;
    property <bool> form-is-clean:
        (mode == 0 || mode == 2) && hide-password
        && inpath == "" && outpath == "" && password == ""
        && password-repeated == "" && keypath == "" && keygen-outdir == ""
        && conflict-warning == "" && status-ok == "" && status-err == "";
    property <string> button-text:
        mode == 0 || mode == 2 ? "Encrypt" :
        mode == 1 || mode == 3 ? "Decrypt" : "Generate Key Pair";
    property <color> strength-color:
        password-strength <= 1 ? #f87171 :
        password-strength == 2 ? #d4a053 :
        password-strength == 3 ? #60a5fa : #34d399;

    // ── Callbacks ───────────────────────────────────────────────────────
    callback mode-changed();
    callback select-input-file();
    callback select-input-folder();
    callback select-key-file();
    callback select-output-dir();
    callback select-output-file();
    callback select-keygen-outdir();
    callback start-operation();
    callback password-edited();
    callback clear-form();

    // ── Accent stripe ───────────────────────────────────────────────────
    Rectangle {
        y: 0;
        width: 100%;
        height: 2px;
        background: @linear-gradient(90deg, #0a0f1a, #06b6d4 50%, #0a0f1a);
    }

    // ── Main layout ─────────────────────────────────────────────────────
    VerticalLayout {
        padding-left: 22px;
        padding-right: 22px;
        padding-top: 28px;
        padding-bottom: 14px;
        spacing: 0px;

        // ── Top section: packs tightly at the top ──
        VerticalLayout {
            spacing: 0px;
            alignment: start;

        // ═══════════ HEADER ═══════════
        Text {
            text: "FerroCrypt";
            color: Theme.text;
            font-size: 20px;
            font-weight: 700;
            horizontal-alignment: center;
        }
        Rectangle { height: 4px; }
        Text {
            text: "Secure File Encryption";
            color: Theme.text-dim;
            font-size: 12px;
            horizontal-alignment: center;
        }

        Rectangle { height: 22px; }

        // ═══════════ MODE SELECTOR ═══════════
        Rectangle {
            height: 38px;
            border-radius: 6px;
            background: Theme.input-bg;
            border-width: 1px;
            border-color: Theme.border;

            HorizontalLayout {
                padding: 3px;
                spacing: 2px;

                // ── Symmetric ──
                Rectangle {
                    property <bool> active: mode == 0 || mode == 1;
                    horizontal-stretch: 1;
                    border-radius: 5px;
                    background: active ? Theme.accent-muted :
                                (sym-ta.has-hover && sym-ta.enabled) ? Theme.surface-hover
                                : transparent;
                    animate background { duration: 150ms; }

                    sym-ta := TouchArea {
                        enabled: mode != 3 && !is-working;
                        mouse-cursor: self.enabled ? pointer : default;
                        clicked => {
                            root.password-strength = 0;
                            root.mode = 0; root.mode-changed();
                        }
                    }
                    Text {
                        text: "Symmetric";
                        color: parent.active ? Theme.text :
                               !sym-ta.enabled ? Theme.text-off : Theme.text-secondary;
                        font-size: Theme.field-text-size;
                        font-weight: parent.active ? 600 : 400;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Rectangle { width: 1px; background: Theme.border; }

                // ── Hybrid ──
                Rectangle {
                    property <bool> active: mode == 2 || mode == 3 || mode == 4;
                    horizontal-stretch: 1;
                    border-radius: 5px;
                    background: active ? Theme.accent-muted :
                                (hyb-ta.has-hover && hyb-ta.enabled) ? Theme.surface-hover
                                : transparent;
                    animate background { duration: 150ms; }

                    hyb-ta := TouchArea {
                        enabled: mode != 1 && !is-working;
                        mouse-cursor: self.enabled ? pointer : default;
                        clicked => {
                            root.password-strength = 0;
                            root.mode = 2; root.mode-changed();
                        }
                    }
                    Text {
                        text: "Hybrid";
                        color: parent.active ? Theme.text :
                               !hyb-ta.enabled ? Theme.text-off : Theme.text-secondary;
                        font-size: Theme.field-text-size;
                        font-weight: parent.active ? 600 : 400;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

            }
        }

        Rectangle { height: 6px; }
        Text {
            text: mode == 0 || mode == 1 ? "Password-based encryption" :
                  mode == 4 ? "Generate RSA-4096 key pair" :
                  "Public/private key encryption";
            color: Theme.text-dim;
            font-size: 11.5px;
            horizontal-alignment: center;
            animate color { duration: 150ms; }
        }

        // ═══════════ INPUT FILE / FOLDER ═══════════
        VerticalLayout {
            spacing: 0px;
            Rectangle { height: Theme.field-gap; }

            Text {
                text: "Select file or folder";
                color: Theme.text-secondary;
                font-size: Theme.label-size;
            }
            Rectangle { height: Theme.label-gap; }

            HorizontalLayout {
                spacing: Theme.row-spacing;

                Rectangle {
                    horizontal-stretch: 1;
                    height: Theme.field-height;
                    border-radius: Theme.field-radius;
                    background: is-working ? Theme.input-bg-disabled : Theme.input-bg;
                    border-width: 1px;
                    border-color: !is-working && inpath-ta.has-hover
                                  ? Theme.border-hover : Theme.border;
                    clip: true;
                    animate background { duration: 150ms; }
                    animate border-color { duration: 150ms; }

                    inpath-ta := TouchArea {
                        enabled: !is-working;
                        mouse-cursor: self.enabled ? pointer : default;
                        clicked => { root.select-input-file(); }
                    }

                    Text {
                        x: Theme.field-pad;
                        width: parent.width - 2 * Theme.field-pad;
                        vertical-alignment: center;
                        text: inpath != "" ? inpath-display : "No file selected";
                        color: inpath != "" ? Theme.text : Theme.text-disabled;
                        font-size: Theme.field-text-size;
                        overflow: elide;
                    }
                }

                if combined-picker : SmallButton {
                    width: Theme.btn-width;
                    label: "Select";
                    enabled: !is-working;
                    clicked => { root.select-input-file(); }
                }
                if !combined-picker : SmallButton {
                    width: Theme.btn-width;
                    label: "File";
                    enabled: !is-working;
                    clicked => { root.select-input-file(); }
                }
                if !combined-picker : SmallButton {
                    width: Theme.btn-width;
                    label: "Folder";
                    enabled: !is-working;
                    clicked => { root.select-input-folder(); }
                }
            }
        }

        // ═══════════ OUTPUT ═══════════
        VerticalLayout {
            spacing: 0px;
            Rectangle { height: Theme.field-gap; }

            Text {
                text: is-encrypt-mode ? "Save encrypted file as" : "Save to";
                color: Theme.text-secondary;
                font-size: Theme.label-size;
            }
            Rectangle { height: Theme.label-gap; }

            HorizontalLayout {
                spacing: Theme.row-spacing;

                Rectangle {
                    property <bool> field-enabled: !is-working && !(is-encrypt-mode && inpath == "");
                    horizontal-stretch: 1;
                    height: Theme.field-height;
                    border-radius: Theme.field-radius;
                    background: !field-enabled ? Theme.input-bg-disabled : Theme.input-bg;
                    border-width: 1px;
                    border-color: field-enabled && out-ta.has-hover
                                  ? Theme.border-hover : Theme.border;
                    clip: true;
                    animate background { duration: 150ms; }
                    animate border-color { duration: 150ms; }

                    out-ta := TouchArea {
                        enabled: parent.field-enabled;
                        mouse-cursor: self.enabled ? pointer : default;
                        clicked => {
                            if (is-encrypt-mode) {
                                root.select-output-file();
                            } else {
                                root.select-output-dir();
                            }
                        }
                    }

                    Text {
                        x: Theme.field-pad;
                        width: parent.width - 2 * Theme.field-pad;
                        vertical-alignment: center;
                        text: outpath != "" ? outpath-display :
                              (is-encrypt-mode ? "No file selected" : "No directory selected");
                        color: outpath != "" ? Theme.text : Theme.text-disabled;
                        font-size: Theme.field-text-size;
                        overflow: elide;
                    }
                }

                SmallButton {
                    width: Theme.btn-width;
                    label: "Change";
                    enabled: !is-working && !(is-encrypt-mode && inpath == "");
                    clicked => {
                        if (is-encrypt-mode) {
                            root.select-output-file();
                        } else {
                            root.select-output-dir();
                        }
                    }
                }
            }
        }

        // ═══════════ DIVIDER ═══════════
        VerticalLayout {
            spacing: 0px;
            Rectangle { height: 22px; }
            Rectangle { height: 1px; background: Theme.border; }
        }

        // ═══════════ HYBRID KEY SECTION ═══════════
        if mode == 2 || mode == 4 : VerticalLayout {
            spacing: 0px;
            Rectangle { height: Theme.field-gap; }

            Text {
                text: "Key source";
                color: Theme.text-secondary;
                font-size: Theme.label-size;
            }
            Rectangle { height: Theme.label-gap; }

            Rectangle {
                height: 30px;
                border-radius: 5px;
                background: Theme.surface;
                border-width: 1px;
                border-color: Theme.border;

                HorizontalLayout {
                    padding: 2px;
                    spacing: 2px;

                    Rectangle {
                        horizontal-stretch: 1;
                        border-radius: 4px;
                        background: mode == 2 ? Theme.accent-muted :
                                    (ek-ta.has-hover && ek-ta.enabled) ? Theme.surface-hover
                                    : transparent;
                        animate background { duration: 150ms; }

                        ek-ta := TouchArea {
                            enabled: !is-working;
                            mouse-cursor: self.enabled ? pointer : default;
                            clicked => {
                                root.password-strength = 0;
                                root.mode = 2; root.mode-changed();
                            }
                        }
                        Text {
                            text: "Use existing key";
                            color: mode == 2 ? Theme.text : Theme.text-secondary;
                            font-size: 11px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    Rectangle { width: 1px; background: Theme.border; }

                    Rectangle {
                        horizontal-stretch: 1;
                        border-radius: 4px;
                        background: mode == 4 ? Theme.accent-muted :
                                    (nk-ta.has-hover && nk-ta.enabled) ? Theme.surface-hover
                                    : transparent;
                        animate background { duration: 150ms; }

                        nk-ta := TouchArea {
                            enabled: !is-working;
                            mouse-cursor: self.enabled ? pointer : default;
                            clicked => {
                                root.password-strength = 0;
                                root.mode = 4; root.mode-changed();
                            }
                        }
                        Text {
                            text: "Create new key pair";
                            color: mode == 4 ? Theme.text : Theme.text-secondary;
                            font-size: 11px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }

        // ═══════════ PASSWORD (SE, SD, HD, GK) ═══════════
        if require-password : VerticalLayout {
            spacing: 0px;
            Rectangle { height: Theme.field-gap; }

            Text {
                text: mode == 3 || mode == 4 ? "Private key password" : "Password";
                color: Theme.text-secondary;
                font-size: Theme.label-size;
            }
            Rectangle { height: Theme.label-gap; }

            Rectangle {
                height: Theme.field-height;
                border-radius: Theme.field-radius;
                background: is-working ? Theme.input-bg-disabled : Theme.input-bg;
                border-width: 1px;
                border-color: pwd-ti.has-focus ? Theme.border-focus :
                              pwd-hover.has-hover && !is-working
                              ? Theme.border-hover : Theme.border;
                animate background { duration: 150ms; }
                animate border-color { duration: 150ms; }

                pwd-hover := TouchArea {
                    enabled: !is-working;
                    mouse-cursor: text;
                    clicked => { pwd-ti.focus(); }
                }

                pwd-ti := TextInput {
                    x: Theme.field-pad;
                    width: parent.width - 40px;
                    y: (parent.height - self.preferred-height) / 2;
                    color: Theme.text;
                    font-size: Theme.input-text-size;
                    text-cursor-width: 2px;
                    selection-background-color: Theme.accent;
                    input-type: hide-password ? InputType.password : InputType.text;
                    text <=> root.password;
                    single-line: true;
                    enabled: !is-working;
                    accepted => {
                        if (!root.disable-start) { root.start-operation(); }
                    }
                    edited => { root.password-edited(); }
                }

                if password == "" && !pwd-ti.has-focus : Text {
                    x: Theme.field-pad;
                    y: (parent.height - self.preferred-height) / 2;
                    text: "Enter password\u{2026}";
                    color: Theme.text-disabled;
                    font-size: Theme.input-text-size;
                }

                // Eye icon (toggle password visibility)
                Rectangle {
                    x: parent.width - 32px;
                    y: (parent.height - 14px) / 2;
                    width: 22px;
                    height: 14px;

                    // Eye outline (oval)
                    Rectangle {
                        width: 18px;
                        height: 10px;
                        x: 2px;
                        y: 2px;
                        border-radius: 5px;
                        border-width: 1.5px;
                        border-color: Theme.text-dim;
                        background: transparent;

                        // Pupil
                        Rectangle {
                            width: 5px;
                            height: 5px;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            border-radius: 2.5px;
                            background: Theme.text-dim;
                        }
                    }

                    // Strike-through (when password is visible)
                    if (!root.hide-password) : Rectangle {
                        width: 22px;
                        height: 1.5px;
                        y: (parent.height - self.height) / 2;
                        background: Theme.text-dim;
                    }
                }

                // Clickable area for the eye
                TouchArea {
                    x: parent.width - 38px;
                    width: 38px;
                    height: parent.height;
                    mouse-cursor: pointer;
                    clicked => { root.hide-password = !root.hide-password; }
                }
            }

            // Password strength indicator (encrypt/keygen only)
            if mode == 0 || mode == 4 : HorizontalLayout {
                spacing: 4px;
                height: 14px;

                property <bool> active: password != "";

                HorizontalLayout {
                    spacing: 2px;
                    horizontal-stretch: 1;
                    padding-top: 5px;

                    Rectangle {
                        horizontal-stretch: 1;
                        height: 2px;
                        border-radius: 1px;
                        background: active && password-strength >= 1 ? strength-color : Theme.surface;
                    }
                    Rectangle {
                        horizontal-stretch: 1;
                        height: 2px;
                        border-radius: 1px;
                        background: active && password-strength >= 2 ? strength-color : Theme.surface;
                    }
                    Rectangle {
                        horizontal-stretch: 1;
                        height: 2px;
                        border-radius: 1px;
                        background: active && password-strength >= 3 ? strength-color : Theme.surface;
                    }
                    Rectangle {
                        horizontal-stretch: 1;
                        height: 2px;
                        border-radius: 1px;
                        background: active && password-strength >= 4 ? strength-color : Theme.surface;
                        animate background { duration: 200ms; }
                    }
                }

                Text {
                    text: active ? (password-strength == 1 ? "Weak" :
                          password-strength == 2 ? "Fair" :
                          password-strength == 3 ? "Good" : "Strong") : "";
                    color: strength-color;
                    font-size: 10px;
                    vertical-alignment: center;
                }
            }
        }

        // ═══════════ CONFIRM PASSWORD (SE, GK — only when pwd hidden) ═══════════
        if require-password-repeated : VerticalLayout {
            spacing: 0px;
            Rectangle { height: 8px; }

            Text {
                text: mode == 4 ? "Confirm private key password" : "Confirm password";
                color: Theme.text-secondary;
                font-size: Theme.label-size;
            }
            Rectangle { height: Theme.label-gap; }

            Rectangle {
                property <bool> field-enabled: !is-working && password != "";
                height: Theme.field-height;
                border-radius: Theme.field-radius;
                background: !field-enabled ? Theme.input-bg-disabled : Theme.input-bg;
                border-width: 1px;
                border-color: rpwd-ti.has-focus ? Theme.border-focus :
                              rpwd-hover.has-hover && field-enabled
                              ? Theme.border-hover : Theme.border;
                animate background { duration: 150ms; }
                animate border-color { duration: 150ms; }

                rpwd-hover := TouchArea {
                    enabled: parent.field-enabled;
                    mouse-cursor: self.enabled ? text : default;
                    clicked => { rpwd-ti.focus(); }
                }

                rpwd-ti := TextInput {
                    x: Theme.field-pad;
                    width: parent.width - 36px;
                    y: (parent.height - self.preferred-height) / 2;
                    color: Theme.text;
                    font-size: Theme.input-text-size;
                    text-cursor-width: 2px;
                    selection-background-color: Theme.accent;
                    input-type: InputType.password;
                    text <=> root.password-repeated;
                    single-line: true;
                    enabled: parent.field-enabled;
                    accepted => {
                        if (!root.disable-start) { root.start-operation(); }
                    }
                }

                if password-repeated == "" && !rpwd-ti.has-focus : Text {
                    x: Theme.field-pad;
                    y: (parent.height - self.preferred-height) / 2;
                    text: "Repeat password\u{2026}";
                    color: Theme.text-disabled;
                    font-size: Theme.input-text-size;
                }

                // Match dot (inside field, right edge)
                if password-repeated != "" : Rectangle {
                    x: parent.width - 22px;
                    y: (parent.height - 10px) / 2;
                    width: 10px;
                    height: 10px;
                    border-radius: 5px;
                    background: password-match ? Theme.success : Theme.error;
                    animate background { duration: 200ms; }
                }
            }
        }

        // ═══════════ RSA KEY (HE, HD) ═══════════
        if require-key : VerticalLayout {
            spacing: 0px;
            Rectangle { height: Theme.field-gap; }

            Text {
                text: mode == 2 ? "Public key (PEM)" : "Private key (PEM)";
                color: Theme.text-secondary;
                font-size: Theme.label-size;
            }
            Rectangle { height: Theme.label-gap; }

            HorizontalLayout {
                spacing: Theme.row-spacing;

                Rectangle {
                    horizontal-stretch: 1;
                    height: Theme.field-height;
                    border-radius: Theme.field-radius;
                    background: is-working ? Theme.input-bg-disabled : Theme.input-bg;
                    border-width: 1px;
                    border-color: !is-working && key-ta.has-hover
                                  ? Theme.border-hover : Theme.border;
                    clip: true;
                    animate background { duration: 150ms; }
                    animate border-color { duration: 150ms; }

                    key-ta := TouchArea {
                        enabled: !is-working;
                        mouse-cursor: self.enabled ? pointer : default;
                        clicked => { root.select-key-file(); }
                    }

                    Text {
                        x: Theme.field-pad;
                        width: parent.width - 2 * Theme.field-pad;
                        vertical-alignment: center;
                        text: keypath != "" ? keypath-display :
                              (mode == 2 ? "Select public key\u{2026}" :
                               "Select private key\u{2026}");
                        color: keypath != "" ? Theme.text : Theme.text-disabled;
                        font-size: Theme.field-text-size;
                        overflow: elide;
                    }
                }

                SmallButton {
                    width: Theme.btn-width;
                    label: "Select";
                    enabled: !is-working;
                    clicked => { root.select-key-file(); }
                }
            }
        }

        // ═══════════ KEY PAIR OUTPUT DIR (GK only) ═══════════
        if mode == 4 : VerticalLayout {
            spacing: 0px;
            Rectangle { height: require-password-repeated ? 18px : 8px; }

            Text {
                text: "Save key pair to";
                color: Theme.text-secondary;
                font-size: Theme.label-size;
            }
            Rectangle { height: Theme.label-gap; }

            HorizontalLayout {
                spacing: Theme.row-spacing;

                Rectangle {
                    horizontal-stretch: 1;
                    height: Theme.field-height;
                    border-radius: Theme.field-radius;
                    background: is-working ? Theme.input-bg-disabled : Theme.input-bg;
                    border-width: 1px;
                    border-color: !is-working && kgout-ta.has-hover
                                  ? Theme.border-hover : Theme.border;
                    clip: true;
                    animate background { duration: 150ms; }
                    animate border-color { duration: 150ms; }

                    kgout-ta := TouchArea {
                        enabled: !is-working;
                        mouse-cursor: self.enabled ? pointer : default;
                        clicked => { root.select-keygen-outdir(); }
                    }

                    Text {
                        x: Theme.field-pad;
                        width: parent.width - 2 * Theme.field-pad;
                        vertical-alignment: center;
                        text: keygen-outdir != "" ? keygen-outdir-display
                              : "No directory selected";
                        color: keygen-outdir != "" ? Theme.text : Theme.text-disabled;
                        font-size: Theme.field-text-size;
                        overflow: elide;
                    }
                }

                SmallButton {
                    width: Theme.btn-width;
                    label: "Change";
                    enabled: !is-working;
                    clicked => { root.select-keygen-outdir(); }
                }
            }
        }

        } // end top section

        // ── Spacer: pushes bottom section to a fixed position ──
        Rectangle { vertical-stretch: 1; }

        // ── Bottom section: always at the same position ──

        // ═══════════ NOTIFICATION BAR ═══════════
        // Priority: error > warning > success/progress. Only one shown at a time.
        Rectangle {
            height: 30px;
            border-radius: 6px;
            background: status-err != "" ? #1c1012 :
                        conflict-warning != "" ? #1a1708 :
                        status-ok != "" ? #0a1a14 : transparent;
            border-width: (status-err != "" || conflict-warning != "" || status-ok != "") ? 1px : 0px;
            border-color: status-err != "" ? #3b1520 :
                          conflict-warning != "" ? #3b3015 :
                          status-ok != "" ? #153b2a : transparent;
            animate background { duration: 200ms; }
            animate border-color { duration: 200ms; }

            Text {
                x: Theme.field-pad;
                width: parent.width - 2 * Theme.field-pad;
                vertical-alignment: center;
                text: status-err != "" ? status-err :
                      conflict-warning != "" ? conflict-warning :
                      status-ok;
                color: status-err != "" ? Theme.error :
                       conflict-warning != "" ? Theme.warning :
                       Theme.success;
                font-size: 11.5px;
                overflow: elide;
            }
        }

        Rectangle { height: 12px; }

        // ═══════════ ACTION ROW ═══════════
        HorizontalLayout {
            spacing: 8px;

            Rectangle {
                width: 54px;
                height: 40px;
                border-radius: 6px;
                background: form-is-clean || is-working ? transparent :
                            reset-ta.has-hover ? Theme.surface-hover : transparent;
                border-width: form-is-clean || is-working ? 0px : 1px;
                border-color: Theme.border;
                animate background { duration: 120ms; }
                animate border-width { duration: 120ms; }

                reset-ta := TouchArea {
                    enabled: !form-is-clean && !is-working;
                    mouse-cursor: self.enabled ? pointer : default;
                    clicked => { root.clear-form(); }
                }

                Text {
                    text: "Reset";
                    color: form-is-clean || is-working ? Theme.text-off : Theme.text-dim;
                    font-size: 11.5px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            Rectangle {
                horizontal-stretch: 1;
                height: 40px;
                border-radius: 6px;
                background: disable-start ? Theme.surface :
                            start-ta.has-hover ? Theme.accent-btn-hover
                            : Theme.accent-btn;
                animate background { duration: 120ms; }

                start-ta := TouchArea {
                    enabled: !disable-start;
                    mouse-cursor: self.enabled ? pointer : default;
                    clicked => { root.start-operation(); }
                }

                Text {
                    text: button-text;
                    color: disable-start ? Theme.text-disabled : Theme.text;
                    font-size: 14px;
                    font-weight: 600;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        Rectangle { height: 10px; }

    }
}
